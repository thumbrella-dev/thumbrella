{
  "name": "Thumbrella Dev",
  "build": {
    "dockerfile": "../Dockerfile",
    "target": "dev"
  },
  "mounts": [
    "source=${localWorkspaceFolder},target=/workspace,type=bind",
    "source=thumbrella-target,target=/workspaces/thumbrella/target,type=volume",
    "source=thumbrella-cargo-registry,target=/usr/local/cargo/registry,type=volume"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "vadimcn.vscode-lldb"
      ],
      "settings": {
      }
    }
  }
}
